<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Quadro Técnico Compartilhado</title>
    <script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>
    <style>
        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
            user-select: none;
        }
        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background-color: #1e1e1e;
            color: #fff;
            overflow: hidden;
            height: 100vh;
            display: flex;
            flex-direction: column;
        }
        #toolbar {
            background-color: #252526;
            padding: 10px 20px;
            display: flex;
            align-items: center;
            gap: 15px;
            border-bottom: 1px solid #3c3c3c;
            z-index: 10;
            flex-wrap: wrap;
        }
        .tool-group {
            display: flex;
            align-items: center;
            gap: 5px;
            background-color: #2d2d2d;
            padding: 5px 10px;
            border-radius: 4px;
            border: 1px solid #3c3c3c;
        }
        label {
            font-size: 12px;
            color: #cccccc;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }
        button, select, input[type="color"] {
            background-color: #3e3e3e;
            color: white;
            border: 1px solid #555;
            padding: 6px 12px;
            border-radius: 4px;
            cursor: pointer;
            font-size: 14px;
            transition: background 0.2s, border-color 0.2s;
        }
        button:hover, select:hover {
            background-color: #4e4e4e;
            border-color: #007acc;
        }
        button.active {
            background-color: #007acc;
            border-color: #0098ff;
        }
        input[type="color"] {
            padding: 2px;
            width: 40px;
            height: 30px;
        }
        #status-container {
            margin-left: auto;
            display: flex;
            align-items: center;
            gap: 8px;
            font-size: 13px;
        }
        .status-dot {
            width: 8px;
            height: 8px;
            border-radius: 50%;
            background-color: #gray;
            transition: background 0.3s;
        }
        .status-online { background-color: #4ecc71; }
        .status-syncing { background-color: #f1c40f; animation: pulse 1s infinite alternate; }
        .status-offline { background-color: #e74c3c; }
        @keyframes pulse {
            from { opacity: 0.5; }
            to { opacity: 1; }
        }
        #canvas-container {
            flex: 1;
            position: relative;
            background-color: #1e1e1e;
            cursor: crosshair;
        }
        canvas {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
        }
        #text-ghost {
            position: absolute;
            background: transparent;
            border: 1px dashed #007acc;
            color: white;
            font-family: inherit;
            font-size: 16px;
            padding: 4px;
            outline: none;
            display: none;
            z-index: 5;
            caret-color: #007acc;
        }
    </style>
</head>
<body>

    <div id="toolbar">
        <div class="tool-group">
            <label>Ferramentas</label>
            <button id="tool-draw" class="active" onclick="setTool('draw')">Caneta</button>
            <button id="tool-line" onclick="setTool('line')">Linha Reta</button>
            <button id="tool-rect" onclick="setTool('rect')">Retângulo</button>
            <button id="tool-text" onclick="setTool('text')">Texto</button>
            <button id="tool-erase" onclick="setTool('erase')">Borracha</button>
        </div>

        <div class="tool-group">
            <label>Customização</label>
            <input type="color" id="prop-color" value="#ffffff" onchange="updateProperties()">
            <select id="prop-thickness" onchange="updateProperties()">
                <option value="2">Fino (2px)</option>
                <option value="5" selected>Médio (5px)</option>
                <option value="10">Grosso (10px)</option>
                <option value="20">Muito Grosso (20px)</option>
            </select>
        </div>

        <button onclick="clearBoard()" style="background-color: #5a1d1d; border-color: #7a2d2d;">Limpar Tudo</button>

        <div id="status-container">
            <div id="status-indicator" class="status-dot status-offline"></div>
            <span id="status-text">Conectando...</span>
        </div>
    </div>

    <div id="canvas-container">
        <canvas id="paintCanvas"></canvas>
        <textarea id="text-ghost" rows="1"></textarea>
    </div>

    <script>
        // Configurações do Supabase (Substitua com suas chaves REAIS se necessário)
        const SUPABASE_URL = "https://SEU_PROJETO.supabase.co"; 
        const SUPABASE_KEY = "SUA_ANON_KEY"; 

        let supabase = null;
        if (SUPABASE_URL !== "https://SEU_PROJETO.supabase.co") {
            supabase = supabase.createClient(SUPABASE_URL, SUPABASE_KEY);
        }

        // Elementos do DOM
        const canvas = document.getElementById('paintCanvas');
        const ctx = canvas.getContext('2d');
        const container = document.getElementById('canvas-container');
        const textGhost = document.getElementById('text-ghost');
        const statusIndicator = document.getElementById('status-indicator');
        const statusText = document.getElementById('status-text');

        // Estado do Quadro
        let currentTool = 'draw'; 
        let config = { color: '#ffffff', thickness: 5 };
        let isDrawing = false;
        let startX = 0, startY = 0;
        let activeElementId = null;

        // Banco de dados local na memória
        let boardElements = [];

        // Inicialização
        function init() {
            resizeCanvas();
            window.addEventListener('resize', resizeCanvas);
            setupCanvasEvents();
            setupTextEvents();
            updateStatus('online', 'Pronto');
            
            if (supabase) {
                loadElementsFromSupabase();
                subscribeToChanges();
            } else {
                updateStatus('offline', 'Modo Local (Sem Supabase)');
            }
        }

        function updateStatus(type, message) {
            statusIndicator.className = 'status-dot';
            if (type === 'online') statusIndicator.classList.add('status-online');
            if (type === 'syncing') statusIndicator.classList.add('status-syncing');
            if (type === 'offline') statusIndicator.classList.add('status-offline');
            statusText.innerText = message;
        }

        function resizeCanvas() {
            const rect = container.getBoundingClientRect();
            canvas.width = rect.width;
            canvas.height = rect.height;
            render();
        }

        function setTool(tool) {
            currentTool = tool;
            document.querySelectorAll('#toolbar button').forEach(b => b.classList.remove('active'));
            const btn = document.getElementById(`tool-${tool}`);
            if (btn) btn.classList.add('active');
            if (tool !== 'text') hideTextGhost();
        }

        function updateProperties() {
            config.color = document.getElementById('prop-color').value;
            config.thickness = parseInt(document.getElementById('prop-thickness').value);
        }

        // Sistema de Desenho e Renderização
        function render() {
            ctx.clearRect(0, 0, canvas.width, canvas.height);
            ctx.lineCap = 'round';
            ctx.lineJoin = 'round';

            boardElements.forEach(el => {
                ctx.strokeStyle = el.color;
                ctx.fillStyle = el.color;
                ctx.lineWidth = el.thickness;

                if (el.type === 'draw' || el.type === 'line') {
                    if (el.pontos && el.pontos.length > 0) {
                        ctx.beginPath();
                        ctx.moveTo(el.pontos[0].x, el.pontos[0].y);
                        for (let i = 1; i < el.pontos.length; i++) {
                            ctx.lineTo(el.pontos[i].x, el.pontos[i].y);
                        }
                        ctx.stroke();
                    }
                } else if (el.type === 'rect') {
                    if (el.pontos && el.pontos.length >= 2) {
                        const p1 = el.pontos[0];
                        const p2 = el.pontos[el.pontos.length - 1];
                        ctx.strokeRect(p1.x, p1.y, p2.x - p1.x, p2.y - p1.y);
                    }
                } else if (el.type === 'text') {
                    if (el.pontos && el.pontos.length > 0) {
                        ctx.font = `${el.thickness * 3 + 12}px sans-serif`;
                        ctx.textBaseline = 'top';
                        ctx.fillText(el.content || '', el.pontos[0].x, el.pontos[0].y);
                    }
                }
            });
        }

        function setupCanvasEvents() {
            const getPos = (e) => {
                const rect = canvas.getBoundingClientRect();
                return { x: e.clientX - rect.left, y: e.clientY - rect.top };
            };

            canvas.addEventListener('mousedown', (e) => {
                if (currentTool === 'text') {
                    showTextGhost(getPos(e));
                    return;
                }
                if (currentTool === 'erase') {
                    eraseElementAt(getPos(e));
                    return;
                }

                isDrawing = true;
                const pos = getPos(e);
                startX = pos.x;
                startY = pos.y;
                activeElementId = 'el_' + Date.now() + '_' + Math.random().toString(36).substr(2, 5);

                const newElement = {
                    id: activeElementId,
                    type: currentTool,
                    color: config.color,
                    thickness: config.thickness,
                    pontos: [pos],
                    content: ''
                };

                boardElements.push(newElement);
                render();
            });

            canvas.addEventListener('mousemove', (e) => {
                if (!isDrawing) return;
                const pos = getPos(e);
                const el = boardElements.find(item => item.id === activeElementId);
                if (!el) return;

                if (currentTool === 'draw') {
                    el.pontos.push(pos);
                } else if (currentTool === 'line' || currentTool === 'rect') {
                    if (el.pontos.length > 1) el.pontos.pop();
                    el.pontos.push(pos);
                }
                render();
            });

            window.addEventListener('mouseup', () => {
                if (!isDrawing) return;
                isDrawing = false;
                const el = boardElements.find(item => item.id === activeElementId);
                if (el) saveElementToSupabase(el);
                activeElementId = null;
            });
        }

        // Sistema de Texto
        function showTextGhost(pos) {
            textGhost.style.display = 'block';
            textGhost.style.left = pos.x + 'px';
            textGhost.style.top = pos.y + 'px';
            textGhost.value = '';
            textGhost.style.color = config.color;
            textGhost.style.fontSize = `${config.thickness * 3 + 12}px`;
            startX = pos.x;
            startY = pos.y;
            setTimeout(() => textGhost.focus(), 50);
        }

        function hideTextGhost() {
            textGhost.style.display = 'none';
        }

        function setupTextEvents() {
            textGhost.addEventListener('keydown', (e) => {
                if (e.key === 'Enter' && !e.shiftKey) {
                    e.preventDefault();
                    finishText();
                }
            });
            textGhost.addEventListener('blur', finishText);
        }

        function finishText() {
            const txt = textGhost.value.trim();
            if (txt && textGhost.style.display === 'block') {
                const id = 'el_' + Date.now() + '_' + Math.random().toString(36).substr(2, 5);
                const newTextEl = {
                    id: id,
                    type: 'text',
                    color: config.color,
                    thickness: config.thickness,
                    pontos: [{ x: startX, y: startY }],
                    content: txt
                };
                boardElements.push(newTextEl);
                render();
                saveElementToSupabase(newTextEl);
            }
            hideTextGhost();
        }

        // Borracha
        function eraseElementAt(pos) {
            let foundIndex = -1;
            for (let i = boardElements.length - 1; i >= 0; i--) {
                const el = boardElements[i];
                if (el.type === 'draw' || el.type === 'line') {
                    for (let p of el.pontos) {
                        if (Math.hypot(p.x - pos.x, p.y - pos.y) < el.thickness + 10) {
                            foundIndex = i;
                            break;
                        }
                    }
                } else if (el.type === 'rect' && el.pontos.length >= 2) {
                    const p1 = el.pontos[0];
                    const p2 = el.pontos[el.pontos.length - 1];
                    const minX = Math.min(p1.x, p2.x), maxX = Math.max(p1.x, p2.x);
                    const minY = Math.min(p1.y, p2.y), maxY = Math.max(p1.y, p2.y);
                    if (pos.x >= minX - 5 && pos.x <= maxX + 5 && pos.y >= minY - 5 && pos.y <= maxY + 5) {
                        foundIndex = i;
                    }
                } else if (el.type === 'text' && el.pontos.length > 0) {
                    if (Math.hypot(el.pontos[0].x - pos.x, el.pontos[0].y - pos.y) < 40) {
                        foundIndex = i;
                    }
                }
                if (foundIndex !== -1) break;
            }

            if (foundIndex !== -1) {
                const targetId = boardElements[foundIndex].id;
                boardElements.splice(foundIndex, 1);
                render();
                deleteElementFromSupabase(targetId);
            }
        }

        function clearBoard() {
            if (confirm("Deseja mesmo limpar todo o quadro para todos os usuários?")) {
                boardElements = [];
                render();
                if (supabase) {
                    updateStatus('syncing', 'Limpando banco...');
                    supabase.from('quadro_elementos').delete().neq('id', '0')
                    .then(() => updateStatus('online', 'Quadro Limpo'));
                }
            }
        }

        // Integração Remota com o Supabase
        async function loadElementsFromSupabase() {
            updateStatus('syncing', 'Buscando dados...');
            const { data, error } = await supabase.from('quadro_elementos').select('*');
            if (error) {
                console.error(error);
                updateStatus('offline', 'Erro ao carregar dados');
            } else if (data) {
                boardElements = data.map(item => ({
                    id: item.element_id,
                    type: item.type,
                    color: item.color,
                    thickness: item.thickness,
                    pontos: typeof item.pontos === 'string' ? JSON.parse(item.pontos) : item.pontos,
                    content: item.content || ''
                }));
                render();
                updateStatus('online', 'Sincronizado');
            }
        }

        async function saveElementToSupabase(el) {
            if (!supabase) return;
            updateStatus('syncing', 'Salvando elemento...');
            const { error } = await supabase.from('quadro_elementos').insert([{
                element_id: el.id,
                type: el.type,
                color: el.color,
                thickness: el.thickness,
                pontos: JSON.stringify(el.pontos),
                content: el.content
            }]);
            if (error) updateStatus('offline', 'Erro de conexão');
            else updateStatus('online', 'Salvo com sucesso');
        }

        async function deleteElementFromSupabase(id) {
            if (!supabase) return;
            updateStatus('syncing', 'Removendo elemento...');
            const { error } = await supabase.from('quadro_elementos').delete().eq('element_id', id);
            if (error) updateStatus('offline', 'Erro ao apagar');
            else updateStatus('online', 'Removido');
        }

        function subscribeToChanges() {
            supabase.channel('custom-filter-channel')
            .on('postgres_changes', { event: '*', schema: 'public', table: 'quadro_elementos' }, (payload) => {
                if (payload.eventType === 'INSERT') {
                    const newItem = payload.new;
                    if (!boardElements.some(el => el.id === newItem.element_id)) {
                        boardElements.push({
                            id: newItem.element_id,
                            type: newItem.type,
                            color: newItem.color,
                            thickness: newItem.thickness,
                            pontos: typeof newItem.pontos === 'string' ? JSON.parse(newItem.pontos) : newItem.pontos,
                            content: newItem.content || ''
                        });
                        render();
                    }
                } else if (payload.eventType === 'DELETE') {
                    // Se o banco foi todo limpo
                    if (!payload.old || !payload.old.element_id) {
                        boardElements = [];
                    } else {
                        boardElements = boardElements.filter(el => el.id !== payload.old.element_id);
                    }
                    render();
                }
            })
            .subscribe();
        }

        // Executa ao carregar a página
        window.onload = init;
    </script>
</body>
</html>
